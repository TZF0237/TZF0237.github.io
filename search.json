---
layout: none
---
[
  {%- assign json_items = "" -%}
  {%- for post in site.posts -%}
    {%- capture item -%}
      {
        "title": {{ post.title | jsonify }},
        "url": "{{ post.url | relative_url }}",
        "date": "{{ post.date | date: '%Y-%m-%d' }}",
        "categories": {{ post.categories | jsonify }},
        "tags": {{ post.tags | jsonify }},
        "excerpt": {{ post.excerpt | strip_html | normalize_whitespace | truncate: 300 | jsonify }},
        "content": {{ post.content | strip_html | normalize_whitespace | truncate: 2000 | jsonify }}
      }
    {%- endcapture -%}
    {%- assign json_items = json_items | append: "%%%" | append: item -%}
  {%- endfor -%}

  {%- for page in site.pages -%}
    {%- if page.title and page.url != "/404.html" and page.url != "/search.json" and page.url != "/sitemap.xml" and page.url != "/feed.xml" and page.search != false and page.title != "" -%}
      {%- capture item -%}
        {
          "title": {{ page.title | jsonify }},
          "url": "{{ page.url | relative_url }}",
          "date": "{% if page.date %}{{ page.date | date: '%Y-%m-%d' }}{% endif %}",
          "categories": [],
          "tags": [],
          "excerpt": {{ page.excerpt | default: "" | strip_html | normalize_whitespace | truncate: 300 | jsonify }},
          "content": {{ page.content | strip_html | normalize_whitespace | truncate: 2000 | jsonify }}
        }
      {%- endcapture -%}
      {%- assign json_items = json_items | append: "%%%" | append: item -%}
    {%- endif -%}
  {%- endfor -%}

  {%- for pub in site.publications -%}
    {%- capture item -%}
      {
        "title": {{ pub.title | jsonify }},
        "url": "{{ pub.url | relative_url }}",
        "date": "{{ pub.date | date: '%Y-%m-%d' }}",
        "categories": ["Publication"],
        "tags": [],
        "excerpt": {{ pub.excerpt | strip_html | normalize_whitespace | truncate: 300 | jsonify }},
        "content": {{ pub.content | strip_html | normalize_whitespace | truncate: 2000 | jsonify }}
      }
    {%- endcapture -%}
    {%- assign json_items = json_items | append: "%%%" | append: item -%}
  {%- endfor -%}

  {%- for comp in site.competitions -%}
    {%- capture item -%}
      {
        "title": {{ comp.title | jsonify }},
        "url": "{{ comp.url | relative_url }}",
        "date": "{{ comp.date | date: '%Y-%m-%d' }}",
        "categories": ["Competition"],
        "tags": {{ comp.tags | jsonify }},
        "excerpt": {{ comp.excerpt | strip_html | normalize_whitespace | truncate: 300 | jsonify }},
        "content": {{ comp.content | strip_html | normalize_whitespace | truncate: 2000 | jsonify }}
      }
    {%- endcapture -%}
    {%- assign json_items = json_items | append: "%%%" | append: item -%}
  {%- endfor -%}

  {%- assign items_array = json_items | split: "%%%" -%}
  {%- for item in items_array -%}
    {%- if item != "" -%}
      {{ item }}{%- unless forloop.last -%},{%- endunless -%}
    {%- endif -%}
  {%- endfor -%}
]
